<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ad="https://github.com/Dirkster99/AvalonDock"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="画面ファイルエディタ" Height="800" Width="1600" Loaded="Window_Loaded">

        <Window.InputBindings>
            <KeyBinding Key="B" Modifiers="Control+Shift" Command="{x:Static local:MainWindow.ColorCommand}" CommandParameter="0" />
            <KeyBinding Key="D1" Modifiers="Control+Shift" Command="{x:Static local:MainWindow.ColorCommand}" CommandParameter="1" />
            <KeyBinding Key="D2" Modifiers="Control+Shift" Command="{x:Static local:MainWindow.ColorCommand}" CommandParameter="2" />
            <KeyBinding Key="D3" Modifiers="Control+Shift" Command="{x:Static local:MainWindow.ColorCommand}" CommandParameter="3" />
            <KeyBinding Key="D4" Modifiers="Control+Shift" Command="{x:Static local:MainWindow.ColorCommand}" CommandParameter="4" />
            <KeyBinding Key="D5" Modifiers="Control+Shift" Command="{x:Static local:MainWindow.ColorCommand}" CommandParameter="5" />
            <KeyBinding Key="D6" Modifiers="Control+Shift" Command="{x:Static local:MainWindow.ColorCommand}" CommandParameter="6" />
            <KeyBinding Key="D7" Modifiers="Control+Shift" Command="{x:Static local:MainWindow.ColorCommand}" CommandParameter="7" />
            <KeyBinding Key="D8" Modifiers="Control+Shift" Command="{x:Static local:MainWindow.ColorCommand}" CommandParameter="8" />
            <KeyBinding Key="D9" Modifiers="Control+Shift" Command="{x:Static local:MainWindow.ColorCommand}" CommandParameter="9" />
        </Window.InputBindings>

    <Grid>
        <!-- 上：メニューバー、下：DockingManager 本体 -->
        <Grid.RowDefinitions>
            <!-- メニュー -->
            <RowDefinition Height="Auto"/>
            <!-- メイン領域 -->
            <RowDefinition Height="*"/>
            <!-- ステータスバー -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- メニューバー -->
        <Menu Grid.Row="0">
            <MenuItem Header="ファイル(_F)">
                <MenuItem Header="新規作成(_N)" />
                <MenuItem Header="開く(_O)" />
                <MenuItem Header="上書き保存(_S)" />
                <MenuItem Header="名前を付けて保存(_A)" />
                <Separator />
                <MenuItem Header="RAMデータ読込" Click="LoadRamData_Click"/>
            </MenuItem>
            <MenuItem Header="編集(_E)" />
            <MenuItem Header="表示(_V)">
                <!-- 右パネルの各タブを表示／非表示切り替え -->
                <MenuItem Header="表記フォーマット パネル" Click="ShowFormatPane_Click" />
                <MenuItem Header="テーブルデータ パネル" Click="ShowTablePane_Click" />
            </MenuItem>
        </Menu>

        <!-- Docking 本体 -->
        <ad:DockingManager Grid.Row="1" x:Name="dockingManager">
            <ad:DockingManager.Layout>
                <ad:LayoutRoot>
                    <ad:LayoutPanel Orientation="Horizontal">
                        <!-- 左側：サイドパネル（上下2分割） -->
                        <ad:LayoutAnchorablePane DockWidth="350">
                            <ad:LayoutAnchorable x:Name="RamCatalogPane" Title="RAMデータ一覧" ContentId="RamCatalogPane" CanClose="False">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" /> <!-- シート選択 -->
                                        <RowDefinition Height="2*" />   <!-- 上：一覧 -->
                                        <RowDefinition Height="Auto" /> <!-- 境界線 -->
                                        <RowDefinition Height="1*" />   <!-- 下：詳細 -->
                                    </Grid.RowDefinitions>

                                    <!-- シート選択 (ComboBox) -->
                                    <StackPanel Grid.Row="0" Margin="5" Orientation="Horizontal">
                                        <TextBlock Text="ページ:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <!-- ViewModelのSheetNamesプロパティと、選択中のSelectedSheetをバインド想定 -->
                                        <ComboBox x:Name="SheetSelector" Width="150" ItemsSource="{Binding SheetNames}" SelectedItem="{Binding SelectedSheet}"/>
                                    </StackPanel>
                                    <!-- 上側：RAMデータ一覧 (DataGrid) -->
                                    <GroupBox Header="RAMデータテーブル" Grid.Row="1" Margin="5">
                                        <DataGrid x:Name="RamCatalogList" ItemsSource="{Binding SelectedSheetData}" SelectedItem="{Binding SelectedRamCatalog}" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="データ" Binding="{Binding Data}" Width="120"/>
                                                <DataGridTextColumn Header="シンボル" Binding="{Binding Symbol}" Width="*"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </GroupBox>

                                    <!-- 分割用スプリッター（ユーザーがサイズ調整可能） -->
                                    <GridSplitter Grid.Row="2" Height="5" HorizontalAlignment="Stretch" Background="#DDD"/>

                                    <!-- 下側：選択データの詳細 (表示専用) -->
                                    <GroupBox Header="詳細情報" Grid.Row="3" Margin="5">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <StackPanel Margin="5">
                                                <DockPanel Margin="0,2">
                                                    <TextBlock Text="データ:" Width="80" FontWeight="Bold"/>
                                                    <!-- RamCatalogから直接取得 -->
                                                    <TextBlock Text="{Binding SelectedRamCatalog.Data}" />
                                                </DockPanel>
                                                <DockPanel Margin="0,2">
                                                    <TextBlock Text="シンボル:" Width="80" FontWeight="Bold"/>
                                                    <!-- RamCatalogから直接取得 -->
                                                    <TextBlock Text="{Binding SelectedRamCatalog.Symbol}" />
                                                </DockPanel>
                                                <DockPanel Margin="0,2">
                                                    <TextBlock Text="アドレス:" Width="80" FontWeight="Bold"/>
                                                    <!-- RamCatalogから直接取得 -->
                                                    <TextBlock Text="{Binding SelectedRamCatalog.Address}" />
                                                </DockPanel>
                                                <DockPanel Margin="0,2">
                                                    <TextBlock Text="単位:" Width="80" FontWeight="Bold"/>
                                                    <!-- リンク先のマスターデータ(FormatData)から取得 -->
                                                    <TextBlock Text="{Binding SelectedRamCatalog.Unit}" />
                                                </DockPanel>
                                                <DockPanel Margin="0,2">
                                                    <TextBlock Text="LSB:" Width="80" FontWeight="Bold"/>
                                                    <!-- リンク先のマスターデータ(FormatData)から取得 -->
                                                    <TextBlock Text="{Binding SelectedRamCatalog.LSB}" />
                                                </DockPanel>
                                                <DockPanel Margin="0,2">
                                                    <TextBlock Text="説明:" Width="80" FontWeight="Bold"/>
                                                    <TextBlock Text="{Binding SelectedRamCatalog.Note}" TextWrapping="Wrap"/>
                                                </DockPanel>
                                            </StackPanel>
                                        </ScrollViewer>
                                    </GroupBox>
                                </Grid>
                            </ad:LayoutAnchorable>
                            <ad:LayoutAnchorable x:Name="FormatPane" Title="表記フォーマット" ContentId="FormatPane" CanHide="True" CanClose="False">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="4*" />
                                        <!-- 上：一覧 -->
                                        <RowDefinition Height="Auto" />
                                        <!-- 境界線 -->
                                        <RowDefinition Height="1*" />
                                        <!-- 下：詳細 -->
                                    </Grid.RowDefinitions>

                                    <!-- 上側：RAMデータ一覧 (DataGrid) -->
                                    <GroupBox Header="データ一覧" Grid.Row="0" Margin="5">
                                        <DataGrid x:Name="FormatList" ItemsSource="{Binding FormatList}" SelectedItem="{Binding SelectedFormat}" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="id" Binding="{Binding Id}" Width="120"/>
                                                <DataGridTextColumn Header="code" Binding="{Binding Code}" Width="40"/>
                                                <DataGridTextColumn Header="length" Binding="{Binding Length}" Width="40"/>
                                                <DataGridTextColumn Header="placeholder" Binding="{Binding Placeholder}" Width="*"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </GroupBox>

                                    <!-- 分割用スプリッター（ユーザーがサイズ調整可能） -->
                                    <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" Background="#DDD"/>

                                    <!-- 下側：選択データの詳細 (表示専用) -->
                                    <GroupBox Header="詳細情報" Grid.Row="2" Margin="5">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <StackPanel Margin="0,5">
                                                <TextBlock Text="{Binding SelectedFormat.Description}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </ScrollViewer>
                                    </GroupBox>
                                </Grid>
                            </ad:LayoutAnchorable>
                        </ad:LayoutAnchorablePane>

                        <!-- 中央：エディタ領域 -->
                        <ad:LayoutDocumentPane>
                            <ad:LayoutDocument Title="エディタ" ContentId="Editor" CanClose="False" CanFloat="False">
                                <!-- Gridで重ね合わせを実現 -->
                                <Grid>
                                    <!-- 背面：ハイライト表示用 (IsHitTestVisible=Falseで操作を無効化) -->
                                    <RichTextBox x:Name="HighlightEditor"
                                         TextOptions.TextFormattingMode="Display"
                                         FontFamily="MS Gothic"
                                         FontSize="14"
                                         Block.LineHeight="1"
                                         Padding="0"
                                         BorderThickness="0"
                                         Background="Black" 
                                         IsHitTestVisible="False"
                                         VerticalScrollBarVisibility="Hidden"
                                         HorizontalScrollBarVisibility="Hidden">
                                        <RichTextBox.Resources>
                                            <Style TargetType="{x:Type Paragraph}">
                                                <Setter Property="Margin" Value="0"/>
                                                <Setter Property="LineHeight" Value="14"/>
                                            </Style>
                                        </RichTextBox.Resources>
                                        <FlowDocument PageWidth="10000">
                                            <Paragraph x:Name="HighlightParagraph"/>
                                        </FlowDocument>
                                    </RichTextBox>

                                    <!-- 前面：文字入力用 (背景を透過) -->
                                    <RichTextBox x:Name="MainEditor"
                                         TextOptions.TextFormattingMode="Display"
                                         FontFamily="MS Gothic"
                                         FontSize="14"
                                         Block.LineHeight="1"
                                         Padding="0"
                                         AcceptsTab="True"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Auto" 
                                         Foreground="#00FF00"
                                         CaretBrush="White"
                     
                                         PreviewKeyDown="MainEditor_PreviewKeyDown"
                                         PreviewKeyUp="MainEditor_PreviewKeyUp"
                                         PreviewLostKeyboardFocus="MainEditor_LostKeyboardFocus"
                                         PreviewMouseLeftButtonDown="MainEditor_PreviewMouseLeftButtonDown"
                                         PreviewMouseMove="MainEditor_PreviewMouseMove"
                                         PreviewMouseLeftButtonUp="MainEditor_PreviewMouseLeftButtonUp"
                     
                                         SelectionChanged="MainEditor_SelectionChanged"
                                         TextChanged="MainEditor_TextChanged" Background="Black">
                                        <RichTextBox.Resources>
                                            <Style TargetType="{x:Type Paragraph}">
                                                <Setter Property="Margin" Value="0"/>
                                                <Setter Property="LineHeight" Value="14"/>
                                            </Style>
                                        </RichTextBox.Resources>
                                        <FlowDocument PageWidth="10000">
                                            <Paragraph x:Name="MainEditorParagraph"/>
                                        </FlowDocument>
                                        <RichTextBox.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="色">
                                                    <!-- 指定の10色をネストして配置 -->
                                                    <MenuItem Header="1:青"   Click="SetColor_Click" Tag="#4040FF" InputGestureText="Ctrl+Shift+1" Foreground="#4040FF"/>
                                                    <MenuItem Header="2:赤"   Click="SetColor_Click" Tag="#FF4040" InputGestureText="Ctrl+Shift+2" Foreground="#FF4040"/>
                                                    <MenuItem Header="3:紫"   Click="SetColor_Click" Tag="#FF00FF" InputGestureText="Ctrl+Shift+3" Foreground="#FF00FF"/>
                                                    <MenuItem Header="4:緑"   Click="SetColor_Click" Tag="#00FF00" InputGestureText="Ctrl+Shift+4" Foreground="#00FF00"/>
                                                    <MenuItem Header="6:黄"   Click="SetColor_Click" Tag="#FFFF00" InputGestureText="Ctrl+Shift+5" Foreground="#FFFF00"/>
                                                    <MenuItem Header="5:水色" Click="SetColor_Click" Tag="#00FFFF" InputGestureText="Ctrl+Shift+6" Foreground="#00FFFF"/>
                                                    <MenuItem Header="7:白"   Click="SetColor_Click" Tag="#FFFFFF" InputGestureText="Ctrl+Shift+7" Foreground="White" Background="Gray"/>
                                                    <MenuItem Header="8:橙"   Click="SetColor_Click" Tag="#FF8000" InputGestureText="Ctrl+Shift+8" Foreground="#FF8000"/>
                                                    <MenuItem Header="9:黄緑" Click="SetColor_Click" Tag="#80FF00" InputGestureText="Ctrl+Shift+9" Foreground="#80FF00"/>
                                                    <MenuItem Header="0:黒"   Click="SetColor_Click" Tag="#000000" InputGestureText="Ctrl+Shift+B" Foreground="Gray"/>
                                                </MenuItem>

                                                <Separator />
                                                <!-- 区切り線 -->

                                                <MenuItem Command="Cut" Header="切り取り" />
                                                <MenuItem Command="Copy" Header="コピー" />
                                                <MenuItem Command="Paste" Header="貼り付け" />
                                            </ContextMenu>
                                        </RichTextBox.ContextMenu>
                                    </RichTextBox>
                                </Grid>
                            </ad:LayoutDocument>

                        </ad:LayoutDocumentPane>

                        <!-- 右側：サイドパネル（上下2分割） -->
                        <ad:LayoutAnchorablePane DockWidth="350">
                            <ad:LayoutAnchorable x:Name="RamDatePane" Title="RAMデータ" ContentId="RamDataPane" CanHide="True" CanClose="False">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="4*" />   <!-- 上：一覧 -->
                                        <RowDefinition Height="Auto" /> <!-- 境界線 -->
                                        <RowDefinition Height="1*" />   <!-- 下：詳細 -->
                                    </Grid.RowDefinitions>

                                    <!-- 上側：RAMデータ一覧 (DataGrid) -->
                                    <GroupBox Header="データ一覧" Grid.Row="0" Margin="5">
                                        <DataGrid x:Name="RamDataList" ItemsSource="{Binding RamdataList}" SelectedItem="{Binding SelectedRamdata}" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="行" Binding="{Binding Row}" Width="40"/>
                                                <DataGridTextColumn Header="桁" Binding="{Binding Column}" Width="40"/>
                                                <DataGridTextColumn Header="データ" Binding="{Binding Data}" Width="*"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </GroupBox>

                                    <!-- 分割用スプリッター（ユーザーがサイズ調整可能） -->
                                    <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" Background="#DDD"/>

                                    <!-- 下側：選択データの詳細 (表示専用) -->
                                    <GroupBox Header="詳細情報" Grid.Row="2" Margin="5">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <StackPanel Margin="0,5">
                                                <TextBlock Text="{Binding SelectedFormat.Description}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </ScrollViewer>
                                    </GroupBox>
                                </Grid>
                            </ad:LayoutAnchorable>
                            
                        </ad:LayoutAnchorablePane>
                    </ad:LayoutPanel>
                </ad:LayoutRoot>
            </ad:DockingManager.Layout>
        </ad:DockingManager>

        <!-- ステータスバーの追加 -->
        <StatusBar Grid.Row="2">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="StatusLineColumn" Text="行:0, 文字:0" Margin="5,0"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>