<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ad="https://github.com/Dirkster99/AvalonDock"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="画面ファイルエディタ" Height="600" Width="1000">

    <Grid>
        <!-- 上：メニューバー、下：DockingManager 本体 -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- メニューバー -->
        <Menu Grid.Row="0">
            <MenuItem Header="_View">
                <!-- 右パネルの各タブを表示／非表示切り替え -->
                <MenuItem Header="表記フォーマット パネル"
                          IsCheckable="True"
                          IsChecked="{Binding ElementName=FormatPane, Path=IsVisible, Mode=TwoWay}" />
                <MenuItem Header="テーブルデータ パネル"
                          IsCheckable="True"
                          IsChecked="{Binding ElementName=TablePane, Path=IsVisible, Mode=TwoWay}" />
            </MenuItem>
        </Menu>

        <!-- Docking 本体 -->
        <ad:DockingManager Grid.Row="1">
            <ad:DockingManager.Layout>
                <ad:LayoutRoot>
                    <ad:LayoutPanel Orientation="Horizontal">

                        <!-- 左：テキストエディタ領域（消せない） -->
                        <ad:LayoutDocumentPane>
                            <ad:LayoutDocument Title="エディタ" CanClose="False" CanFloat="False">
                                <RichTextBox FontFamily="MS Gothic"
                                             Grid.Column="1"
                                             FontSize="14"
                                             Block.LineHeight="1"
                                             AcceptsTab="True"
                                             AcceptsReturn="True"
                                             VerticalScrollBarVisibility="Auto"
                                    HorizontalScrollBarVisibility="Auto" Background="Black" Foreground="White" />
                            </ad:LayoutDocument>
                        </ad:LayoutDocumentPane>

                        <!-- 右：2タブ構成のパネル（×で閉じられ、メニューから復活可能） -->
                        <ad:LayoutAnchorablePane DockWidth="320">

                            <!-- タブ1：表記フォーマット -->
                            <ad:LayoutAnchorable x:Name="FormatPane"
                                                 Title="表記フォーマット"
                                                 CanHide="True"
                                                 CanClose="True">
                                <!-- 上下2分割（上：リスト、下：詳細） -->
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="2*" />
                                        <RowDefinition Height="5" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <!-- 上：format_def.yaml の formats リスト -->
                                    <ListView x:Name="FormatList"
                                              Grid.Row="0"
                                              ItemsSource="{Binding Formats}"
                                              SelectedItem="{Binding SelectedFormat, Mode=TwoWay}">
                                        <ListView.View>
                                            <GridView>
                                                <GridViewColumn Header="code" DisplayMemberBinding="{Binding code}" Width="50"/>
                                                <GridViewColumn Header="id" DisplayMemberBinding="{Binding id}" Width="100"/>
                                                <GridViewColumn Header="length" DisplayMemberBinding="{Binding length}" Width="60"/>
                                                <GridViewColumn Header="placeholder" DisplayMemberBinding="{Binding placeholder}" Width="120"/>
                                            </GridView>
                                        </ListView.View>
                                    </ListView>

                                    <!-- 中央：上下のサイズを調整するスプリッタ -->
                                    <GridSplitter Grid.Row="1"
                                                  Height="5"
                                                  HorizontalAlignment="Stretch"
                                                  VerticalAlignment="Center"
                                                  Background="LightGray" />

                                    <!-- 下：選択中フォーマットの詳細表示 -->
                                    <Border Grid.Row="2" BorderBrush="Gray" BorderThickness="1" Padding="6">
                                        <!-- 詳細表示は FormatList の SelectedItem にバインド -->
                                        <Grid DataContext="{Binding ElementName=FormatList, Path=SelectedItem}">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="code:" FontWeight="Bold" Margin="0,0,4,2"/>
                                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding code}"/>

                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="id:" FontWeight="Bold" Margin="0,2,4,2"/>
                                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding id}"/>

                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="length:" FontWeight="Bold" Margin="0,2,4,2"/>
                                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding length}"/>

                                            <TextBlock Grid.Row="3" Grid.Column="0" Text="placeholder:" FontWeight="Bold" Margin="0,2,4,2"/>
                                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding placeholder}"/>

                                            <TextBlock Grid.Row="4" Grid.Column="0" Text="description:" FontWeight="Bold" Margin="0,2,4,0"/>
                                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding description}"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </ad:LayoutAnchorable>

                            <!-- タブ2：テーブルデータ（現時点ではプレースホルダ） -->
                            <ad:LayoutAnchorable x:Name="TablePane"
                                                 Title="テーブルデータ"
                                                 CanHide="True"
                                                 CanClose="True">
                                <Grid>
                                    <TextBlock Text="テーブルデータ（未実装）"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="Gray" />
                                </Grid>
                            </ad:LayoutAnchorable>

                        </ad:LayoutAnchorablePane>

                    </ad:LayoutPanel>
                </ad:LayoutRoot>
            </ad:DockingManager.Layout>
        </ad:DockingManager>
    </Grid>
</Window>