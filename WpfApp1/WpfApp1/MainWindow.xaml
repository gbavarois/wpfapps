<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ad="https://github.com/Dirkster99/AvalonDock"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="画面ファイルエディタ" Height="800" Width="1600">

    <Window.InputBindings>
        <KeyBinding Key="B" Modifiers="Control+Shift" Command="{x:Static local:MainWindow.ColorCommand}" CommandParameter="0" />
        <KeyBinding Key="D1" Modifiers="Control+Shift" Command="{x:Static local:MainWindow.ColorCommand}" CommandParameter="1" />
        <KeyBinding Key="D2" Modifiers="Control+Shift" Command="{x:Static local:MainWindow.ColorCommand}" CommandParameter="2" />
        <KeyBinding Key="D3" Modifiers="Control+Shift" Command="{x:Static local:MainWindow.ColorCommand}" CommandParameter="3" />
        <KeyBinding Key="D4" Modifiers="Control+Shift" Command="{x:Static local:MainWindow.ColorCommand}" CommandParameter="4" />
        <KeyBinding Key="D5" Modifiers="Control+Shift" Command="{x:Static local:MainWindow.ColorCommand}" CommandParameter="5" />
        <KeyBinding Key="D6" Modifiers="Control+Shift" Command="{x:Static local:MainWindow.ColorCommand}" CommandParameter="6" />
        <KeyBinding Key="D7" Modifiers="Control+Shift" Command="{x:Static local:MainWindow.ColorCommand}" CommandParameter="7" />
        <KeyBinding Key="D8" Modifiers="Control+Shift" Command="{x:Static local:MainWindow.ColorCommand}" CommandParameter="8" />
        <KeyBinding Key="D9" Modifiers="Control+Shift" Command="{x:Static local:MainWindow.ColorCommand}" CommandParameter="9" />
    </Window.InputBindings>
    <Window.Resources>
        <!-- Window内のすべてのDataGridに適用される -->
        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#808080" />
        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="White" />
        <!--local:MainViewModel x:Key="MainVM" /-->
        <local:PosConverter x:Key="CharToPosConverter" Scale="7.0" />
        <local:PosConverter x:Key="LineToPosConverter" Scale="14.0" />
        <local:PosConverter x:Key="LenToWidthConverter" Scale="7.0" />

        <DataTemplate x:Key="EditorTemplate">
            <Grid>
                <!-- テキスト入力層（背景を黒、文字を緑に固定） -->
                <RichTextBox x:Name="MainEditor"
                     TextOptions.TextFormattingMode="Display"
                     TextOptions.TextRenderingMode="ClearType"
                     FontFamily="MS Gothic"
                     FontSize="14"
                     Background="LightGray"
                     Padding="0"
                     BorderThickness="0"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     SelectionChanged="MainEditor_SelectionChanged">
                    <RichTextBox.Resources>
                        <Style TargetType="{x:Type Paragraph}">
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="LineHeight" Value="14"/>
                            <Setter Property="LineStackingStrategy" Value="BlockLineHeight"/>
                        </Style>
                        <Style TargetType="{x:Type Run}">
                            <Setter Property="Background" Value="Black" />
                            <Setter Property="Foreground" Value="#00FF00" />
                        </Style>

                    </RichTextBox.Resources>
                    <FlowDocument PagePadding="0" PageWidth="10000">
                        <Paragraph x:Name="MainEditorParagraph"/>
                    </FlowDocument>
                    <RichTextBox.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="色">
                                <!-- 指定の10色をネストして配置 -->
                                <MenuItem Header="1:青"   Click="SetColor_Click" Tag="1" InputGestureText="Ctrl+Shift+1" Foreground="#4040FF"/>
                                <MenuItem Header="2:赤"   Click="SetColor_Click" Tag="2" InputGestureText="Ctrl+Shift+2" Foreground="#FF4040" />
                                <MenuItem Header="3:紫"   Click="SetColor_Click" Tag="3" InputGestureText="Ctrl+Shift+3" Foreground="#FF00FF"/>
                                <MenuItem Header="4:緑"   Click="SetColor_Click" Tag="4" InputGestureText="Ctrl+Shift+4" Foreground="#00FF00"/>
                                <MenuItem Header="6:黄"   Click="SetColor_Click" Tag="5" InputGestureText="Ctrl+Shift+5" Foreground="#FFFF00"/>
                                <MenuItem Header="5:水色" Click="SetColor_Click" Tag="6" InputGestureText="Ctrl+Shift+6" Foreground="#00FFFF"/>
                                <MenuItem Header="7:白"   Click="SetColor_Click" Tag="7" InputGestureText="Ctrl+Shift+7" Foreground="White" Background="Gray"/>
                                <MenuItem Header="8:橙"   Click="SetColor_Click" Tag="8" InputGestureText="Ctrl+Shift+8" Foreground="#FF8000"/>
                                <MenuItem Header="9:黄緑" Click="SetColor_Click" Tag="9" InputGestureText="Ctrl+Shift+9" Foreground="#80FF00"/>
                                <MenuItem Header="0:黒"   Click="SetColor_Click" Tag="0" InputGestureText="Ctrl+Shift+B" Foreground="Gray"/>
                            </MenuItem>
                            <MenuItem Header="RAMデータを配置" />

                            <Separator />
                            <!-- 区切り線 -->

                            <MenuItem Command="Cut" Header="切り取り" />
                            <MenuItem Command="Copy" Header="コピー" />
                            <MenuItem Command="Paste" Header="貼り付け" />
                        </ContextMenu>
                    </RichTextBox.ContextMenu>
                </RichTextBox>

                <!-- RAM枠表示層（最前面） -->
                <!-- Background="{x:Null}" でテキスト入力を邪魔しないようにする -->
                <!-- Canvas部分を以下に置き換え -->
                <ItemsControl x:Name="MyItemsControl" ItemsSource="{Binding PlacedRams}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <!-- RenderTransform はコードビハインドから操作してもOK -->
                            <Canvas x:Name="RamCanvas" Background="{x:Null}" IsHitTestVisible="True" Margin="4,0,0,0" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <!-- 座標を RamData の Column/Row と直接つなぐ -->
                            <Setter Property="Canvas.Left" Value="{Binding Column, Converter={StaticResource CharToPosConverter}}" />
                            <Setter Property="Canvas.Top" Value="{Binding Row, Converter={StaticResource LineToPosConverter}}" />
                        </Style>
                    </ItemsControl.ItemContainerStyle>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- 従来の Thumb の設定をここに凝縮 -->
                            <Thumb Width="{Binding Length, Converter={StaticResource LenToWidthConverter}}" 
                           Height="14" 
                           DragDelta="Thumb_DragDelta"
                           PreviewMouseLeftButtonDown="Thumb_MouseDown">
                                <Thumb.Template>
                                    <ControlTemplate TargetType="Thumb">
                                        <Border x:Name="brd" Background="#80FFFFFF">
                                            <VisualStateManager.VisualStateGroups>
                                                <VisualStateGroup x:Name="SelectionStates">
                                                    <VisualState x:Name="Selected">
                                                        <Storyboard>
                                                            <ColorAnimation Storyboard.TargetName="brd" Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="#66FF0000" Duration="0"/>
                                                        </Storyboard>
                                                    </VisualState>
                                                    <VisualState x:Name="Unselected"/>
                                                </VisualStateGroup>
                                            </VisualStateManager.VisualStateGroups>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                <Setter TargetName="brd" Property="Background" Value="#66FF0000"/>
                                            </DataTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Thumb.Template>
                            </Thumb>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </DataTemplate>
    </Window.Resources>
    
    

    <Grid>
        <!-- 上：メニューバー、下：DockingManager 本体 -->
        <Grid.RowDefinitions>
            <!-- メニュー -->
            <RowDefinition Height="Auto"/>
            <!-- メイン領域 -->
            <RowDefinition Height="*"/>
            <!-- ステータスバー -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- メニューバー -->
        <Menu Grid.Row="0">
            <MenuItem Header="ファイル(_F)">
                <!-- MainViewModel に実装したコマンドを呼び出す -->
                <MenuItem Header="新規作成(_N)" Command="{Binding AddTabCommand}"/>
                <MenuItem Header="開く(_O)" Click="OpenFile_Click"/>
                <MenuItem Header="上書き保存(_S)" Command="{Binding SaveFileCommand}"/>
                <MenuItem Header="名前を付けて保存(_A)" Click="SaveAsFile_Click"/>
                <Separator />
                <MenuItem Header="RAMデータ読込" Click="LoadRamData_Click"/>
                
            </MenuItem>
            <MenuItem Header="編集(_E)">
                <!-- 選択中のみ有効になるコマンド -->
                <MenuItem Header="RAMデータを配置" Command="{Binding AddRamFromCatalogCommand}"/>
                <MenuItem Header="配置RAMを削除" Command="{Binding RemoveRamCommand}"/>
            </MenuItem>
            <MenuItem Header="表示(_V)">
                <!-- 右パネルの各タブを表示／非表示切り替え -->
                <MenuItem Header="表記フォーマット パネル" Click="ShowFormatPane_Click" />
                <MenuItem Header="テーブルデータ パネル" Click="ShowTablePane_Click" />
            </MenuItem>
        </Menu>

        <!-- Docking 本体 -->
        <ad:DockingManager Grid.Row="1"
                           x:Name="dockingManager"
                           DocumentsSource="{Binding EditorTabs}"
                           ActiveContent="{Binding ActiveTab, Mode=TwoWay}"
                           LayoutItemTemplate="{StaticResource EditorTemplate}">
            
            <ad:DockingManager.DocumentHeaderTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding DisplayNumber}" />
                </DataTemplate>
            </ad:DockingManager.DocumentHeaderTemplate>
            
            <ad:DockingManager.LayoutItemContainerStyle>
                <Style TargetType="ad:LayoutItem">
                    <Setter Property="Title" Value="{Binding DisplayNumber}" />
                </Style>
            </ad:DockingManager.LayoutItemContainerStyle>

           
            
            <ad:DockingManager.Layout>
                <ad:LayoutRoot>
                    <ad:LayoutPanel Orientation="Horizontal">
                        <!-- 左側：サイドパネル（上下2分割） -->
                        <ad:LayoutAnchorablePane DockWidth="350">
                            <ad:LayoutAnchorable x:Name="RamCatalogPane" Title="変数一覧" ContentId="RamCatalogPane" CanClose="False">
                                <Grid DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <!-- シート選択 -->
                                        <RowDefinition Height="*" />
                                        <!-- 上：一覧 -->
                                        <RowDefinition Height="Auto" />
                                        <!-- 境界線 -->
                                        <RowDefinition Height="180" />
                                        <!-- 下：詳細 -->
                                    </Grid.RowDefinitions>

                                    <!-- シート選択 (ComboBox) -->
                                    <StackPanel Grid.Row="0" Margin="5" Orientation="Horizontal">
                                        <TextBlock Text="ページ:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <!-- ViewModelのSheetNamesプロパティと、選択中のSelectedSheetをバインド想定 -->
                                        <ComboBox x:Name="SheetSelector" Width="150" ItemsSource="{Binding SheetNames}" SelectedItem="{Binding SelectedSheet}"/>
                                    </StackPanel>
                                    <!-- 上側：RAMデータ一覧 (DataGrid) -->
                                    <Border Grid.Row="1" Margin="2" BorderBrush="LightGray" BorderThickness="1">
                                        <DataGrid x:Name="RamCatalogList" ItemsSource="{Binding CurrentCatalogs}" SelectedItem="{Binding SelectedRamCatalog}" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="データ名" Binding="{Binding Data}" Width="120"/>
                                                <DataGridTextColumn Header="シンボル" Binding="{Binding Symbol}" Width="*"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Border>

                                    <!-- 分割用スプリッター（ユーザーがサイズ調整可能） -->
                                    <GridSplitter Grid.Row="2" Height="5" HorizontalAlignment="Stretch" Background="#DDD"/>

                                    <!-- 下側：選択データの詳細 (表示専用) -->
                                    <GroupBox Header="詳細情報" Grid.Row="3" Margin="5">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <StackPanel Margin="5">
                                                <DockPanel Margin="0,2">
                                                    <TextBlock Text="データ名:" Width="80" FontWeight="Bold"/>
                                                    <!-- RamCatalogから直接取得 -->
                                                    <TextBlock Text="{Binding SelectedRamCatalog.Data}" />
                                                </DockPanel>
                                                <DockPanel Margin="0,2">
                                                    <TextBlock Text="シンボル:" Width="80" FontWeight="Bold"/>
                                                    <!-- RamCatalogから直接取得 -->
                                                    <TextBlock Text="{Binding SelectedRamCatalog.Symbol}" />
                                                </DockPanel>
                                                <DockPanel Margin="0,2">
                                                    <TextBlock Text="アドレス:" Width="80" FontWeight="Bold"/>
                                                    <!-- RamCatalogから直接取得 -->
                                                    <TextBlock Text="{Binding SelectedRamCatalog.Address}" />
                                                </DockPanel>
                                                <DockPanel Margin="0,2">
                                                    <TextBlock Text="単位:" Width="80" FontWeight="Bold"/>
                                                    <!-- リンク先のマスターデータ(FormatData)から取得 -->
                                                    <TextBlock Text="{Binding SelectedRamCatalog.Unit}" />
                                                </DockPanel>
                                                <DockPanel Margin="0,2">
                                                    <TextBlock Text="LSB:" Width="80" FontWeight="Bold"/>
                                                    <!-- リンク先のマスターデータ(FormatData)から取得 -->
                                                    <TextBlock Text="{Binding SelectedRamCatalog.LSB}" />
                                                </DockPanel>
                                                <DockPanel Margin="0,2">
                                                    <TextBlock Text="説明:" Width="80" FontWeight="Bold"/>
                                                    <TextBlock Text="{Binding SelectedRamCatalog.Note}" TextWrapping="Wrap"/>
                                                </DockPanel>
                                            </StackPanel>
                                        </ScrollViewer>
                                    </GroupBox>
                                </Grid>
                            </ad:LayoutAnchorable>
                            <ad:LayoutAnchorable x:Name="FormatPane" Title="表記フォーマット" ContentId="FormatPane" CanHide="True" CanClose="False">
                                <Grid DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <!-- 上：一覧 -->
                                        <RowDefinition Height="Auto" />
                                        <!-- 境界線 -->
                                        <RowDefinition Height="100" />
                                        <!-- 下：詳細 -->
                                    </Grid.RowDefinitions>

                                    <!-- 上側：RAMデータ一覧 (DataGrid) -->
                                    <Border Grid.Row="0" Margin="5" BorderBrush="LightGray" BorderThickness="1">
                                        <DataGrid x:Name="FormatList" ItemsSource="{Binding FormatList}" SelectedItem="{Binding SelectedFormat}" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="id" Binding="{Binding Id}" Width="120"/>
                                                <DataGridTextColumn Header="code" Binding="{Binding Code}" Width="40"/>
                                                <DataGridTextColumn Header="length" Binding="{Binding Length}" Width="40"/>
                                                <DataGridTextColumn Header="placeholder" Binding="{Binding Placeholder}" Width="*"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Border>

                                    <!-- 分割用スプリッター（ユーザーがサイズ調整可能） -->
                                    <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" Background="#DDD"/>

                                    <!-- 下側：選択データの詳細 (表示専用) -->
                                    <GroupBox Header="詳細情報" Grid.Row="2" Margin="5">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <StackPanel Margin="0,5">
                                                <TextBlock Text="{Binding SelectedFormat.Description}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </ScrollViewer>
                                    </GroupBox>
                                </Grid>
                            </ad:LayoutAnchorable>
                        </ad:LayoutAnchorablePane>

                        <!-- 中央：エディタ領域 -->
                        <ad:LayoutDocumentPane />

                        <!-- 右側：サイドパネル（上下2分割） -->
                        <ad:LayoutAnchorablePane DockWidth="350">
                            <ad:LayoutAnchorable x:Name="RamDatePane" Title="配置RAMデータ" ContentId="RamDataPane" CanHide="True" CanClose="False">
                                <Grid DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />   <!-- 上：一覧 -->
                                        <RowDefinition Height="Auto" /> <!-- 境界線 -->
                                        <RowDefinition Height="125" />   <!-- 下：詳細 -->
                                    </Grid.RowDefinitions>

                                    <!-- 上側：RAMデータ一覧 (DataGrid) -->
                                    <Border Grid.Row="0" Margin="5" BorderBrush="LightGray" BorderThickness="1">
                                        <DataGrid x:Name="RamItemVMList"
                                                  ItemsSource="{Binding ActiveTab.PlacedRams}"
                                                  SelectedItem="{Binding ActiveTab.SelectedRam}"
                                                  AutoGenerateColumns="False"
                                                  CanUserAddRows="False"
                                                  SelectionMode="Single">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="行" Binding="{Binding Row}" Width="30"/>
                                                <DataGridTextColumn Header="桁" Binding="{Binding Column}" Width="30"/>
                                                <DataGridTextColumn Header="データ名" Binding="{Binding Data, Mode=OneWay}" IsReadOnly="True" Width="*">
                                                    <DataGridTextColumn.ElementStyle>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsValid}" Value="False">
                                                                    <Setter Property="Foreground" Value="Red"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </DataGridTextColumn.ElementStyle>
                                                </DataGridTextColumn>
                                                <DataGridTextColumn Header="オフセット" Binding="{Binding Offset, Mode=TwoWay}" Width="55"/>
                                                <DataGridComboBoxColumn Header="表記ID"
                                                                        Width="80"
                                                                        SelectedValueBinding="{Binding FormatId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                        SelectedValuePath="Id"
                                                                        DisplayMemberPath="Id">
                                                    <DataGridComboBoxColumn.ElementStyle>
                                                        <Style TargetType="ComboBox">
                                                            <Setter Property="ItemsSource" Value="{Binding DataContext.FormatList, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"/>
                                                            <Setter Property="IsHitTestVisible" Value="False"/>
                                                            <Setter Property="Focusable" Value="False"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsValid}" Value="False">
                                                                    <Setter Property="Foreground" Value="Red"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </DataGridComboBoxColumn.ElementStyle>
                                                    <DataGridComboBoxColumn.EditingElementStyle>
                                                        <Style TargetType="ComboBox">
                                                            <Setter Property="ItemsSource" Value="{Binding DataContext.FormatList, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"/>
                                                        </Style>
                                                    </DataGridComboBoxColumn.EditingElementStyle>

                                                </DataGridComboBoxColumn>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Border>

                                    <!-- 分割用スプリッター（ユーザーがサイズ調整可能） -->
                                    <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" Background="#DDD"/>

                                    <!-- 下側：選択データの詳細 (表示専用) -->
                                    <GroupBox Header="詳細情報" Grid.Row="2" Margin="5">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <StackPanel Margin="5">

                                                <DockPanel Margin="0,2">
                                                    <TextBlock Text="データ名:" Width="90" FontWeight="Bold"/>
                                                    <TextBlock Text="{Binding ActiveTab.SelectedRam.Data}" />
                                                </DockPanel>

                                                <DockPanel Margin="0,2">
                                                    <TextBlock Text="シンボル:" Width="90" FontWeight="Bold"/>
                                                    <TextBlock Text="{Binding ActiveTab.SelectedRam.Symbol}" />
                                                </DockPanel>

                                                <DockPanel Margin="0,2">
                                                    <TextBlock Text="アドレス:" Width="90" FontWeight="Bold"/>
                                                    <TextBlock Text="{Binding ActiveTab.SelectedRam.ComputedAddress}" />
                                                </DockPanel>

                                                <DockPanel Margin="0,2">
                                                    <TextBlock Text="プレースホルダ:" Width="90" FontWeight="Bold"/>
                                                    <TextBlock Text="{Binding ActiveTab.SelectedRam.Placeholder}" />
                                                </DockPanel>

                                            </StackPanel>
                                        </ScrollViewer>
                                    </GroupBox>
                                </Grid>
                            </ad:LayoutAnchorable>
                            
                        </ad:LayoutAnchorablePane>
                    </ad:LayoutPanel>
                </ad:LayoutRoot>
            </ad:DockingManager.Layout>
        </ad:DockingManager>

        <!-- ステータスバーの追加 -->
        <StatusBar Grid.Row="2">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="StatusLineColumn" Text="行:0, 文字:0" Margin="5,0"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>